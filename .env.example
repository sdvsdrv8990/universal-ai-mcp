# ─── Server ───────────────────────────────────────────────────────────────────
MCP_SERVER_NAME=universal-ai-mcp
MCP_SERVER_VERSION=1.0.0
MCP_TRANSPORT=http          # http | stdio
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_AUTH_SECRET=change-me-in-production

# ─── LLM Providers ────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ─── Default Routing ──────────────────────────────────────────────────────────
# Provider priority: anthropic | openrouter | ollama
LLM_DEFAULT_PROVIDER=anthropic
LLM_PLANNING_MODEL=claude-sonnet-4-6
LLM_CONTEXT_MODEL=claude-haiku-4-5-20251001
LLM_EXECUTION_MODEL=claude-sonnet-4-6

# ─── Context Optimization ─────────────────────────────────────────────────────
# Max tokens before compression triggers
CONTEXT_MAX_TOKENS=150000
# Target utilization after compression (0.0 – 1.0)
CONTEXT_TARGET_RATIO=0.6
# Minimum similarity score to merge IdeaBlocks (0.0 – 1.0)
IDEA_BLOCK_MERGE_THRESHOLD=0.85

# ─── Planning Gate ─────────────────────────────────────────────────────────────
# Complexity thresholds: simple <3 steps, medium 3-7, complex >7
PLANNING_COMPLEXITY_THRESHOLD_MEDIUM=3
PLANNING_COMPLEXITY_THRESHOLD_COMPLEX=7
# Require explicit approval before execution
PLANNING_REQUIRE_APPROVAL=true

# ─── GitHub Integration (solutions finder) ────────────────────────────────────
GITHUB_TOKEN=
GITHUB_SEARCH_MAX_RESULTS=10

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json         # json | text
